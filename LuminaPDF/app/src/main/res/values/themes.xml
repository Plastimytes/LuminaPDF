<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme — Compose handles all visual theming, this just satisfies the Window -->
    <style name="Theme.LuminaPDF" parent="android:Theme.Material.NoTitleBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash screen theme using the core-splashscreen library -->
    <style name="Theme.LuminaPDF.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0D1117</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="windowSplashScreenAnimationDuration">400</item>
        <item name="postSplashScreenTheme">@style/Theme.LuminaPDF</item>
    </style>
</resources>
